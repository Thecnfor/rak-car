# vehicle_wbt 8.10 比赛 — 任务站位配置示例
#
# 把这个文件复制为 config_mission.yml 并按实际场地校准坐标
# 加载: from tools import get_yaml; cfg = get_yaml('config_mission.yml')
#
# 坐标系: x=前方, y=左方, theta=逆时针为正 (弧度)
# 单位: 米

seeding_stations:  # 播种点 — 3 个固定位置
  - [0.45, 0.55, 0.785]   # seed_1 — 前方 0.45m, 左 0.55m, 45°
  - [0.60, 0.70, 0.785]   # seed_2
  - [0.75, 0.85, 0.785]   # seed_3

crop_stations:  # 采收作物位置
  - [0.4, 0.3, 0.0]
  - [0.5, 0.3, 0.0]
  - [0.6, 0.3, 0.0]

# 配送站位
delivery_stations:
  A: [0.9, 0.3, 0.0]
  B: [0.9, 0.6, 0.0]
  C: [0.9, 0.9, 0.0]

# 任务参数
mission:
  scan_passes: 2              # 除害侦察扫描次数
  eject_x: 0.5                # 射击弹簧拉伸距离 (米)
  eject_vel: 0.05             # 射击弹簧回弹速度
  harvest_threshold: 0.7       # 采收检测置信度阈值
  order_board: [0.8, 0.0, 0.0]  # OCR 读单板位置

# OCR 服务 (从 config_car.yml 复制)
ocr:
  host: 127.0.0.1
  port: 5004
  timeout_sec: 5.0
