#!/usr/bin/env python3
"""Entry-point wrapper for mc602_peripheral_node console script.

Adds the install's site-packages + the colocated msgs package's
dist-packages to sys.path before importing, so the wrapper works
whether or not setup.bash was sourced.
"""
import os
import sys

_INSTALL = os.path.normpath(os.path.join(os.path.dirname(os.path.abspath(__file__)), '..', '..', '..'))
for _sub in (
    ('vehicle_wbt_smartcar_bridge', 'lib', 'python3.10', 'site-packages'),
    ('vehicle_wbt_smartcar_msgs', 'local', 'lib', 'python3.10', 'dist-packages'),
):
    _p = os.path.join(_INSTALL, *_sub)
    if os.path.isdir(_p) and _p not in sys.path:
        sys.path.insert(0, _p)

from vehicle_wbt_smartcar_bridge.mc602_peripheral_node import main

if __name__ == '__main__':
    main()