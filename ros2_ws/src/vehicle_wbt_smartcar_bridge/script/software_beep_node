#!/usr/bin/env python3
"""Entry-point wrapper for software_beep_node console script.

Adds the install's site-packages to sys.path before importing, so the
wrapper works whether or not setup.bash was sourced.
"""
import os
import sys

_HERE = os.path.dirname(os.path.abspath(__file__))
_SITE_PACKAGES = os.path.normpath(os.path.join(_HERE, '..', '..', 'lib', 'python3.10', 'site-packages'))
if _SITE_PACKAGES not in sys.path:
    sys.path.insert(0, _SITE_PACKAGES)

from vehicle_wbt_smartcar_bridge.software_beep_node import main

if __name__ == '__main__':
    main()